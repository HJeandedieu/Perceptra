# ---------------------------------------------------------------
# Perceptra AI Engine — Environment Variables
# Copy this to .env and fill in your values
# ---------------------------------------------------------------

# ---------------------------------------------------------------
# Stream source
# Examples:
#   0                                    → default webcam
#   rtsp://admin:pass@192.168.1.64/stream1  → IP camera
#   http://192.168.1.64:8080/video       → HTTP stream
# ---------------------------------------------------------------
STREAM_URL=0

# ---------------------------------------------------------------
# Model
# ---------------------------------------------------------------
MODEL_PATH=models/yolov8n.pt
CONFIDENCE_THRESHOLD=0.45

# Only detect specific YOLO classes (comma-separated indices)
# Leave empty to detect all classes
# 0=person, 1=bicycle, 2=car, 43=knife, 67=cell phone
TARGET_CLASSES=

# ---------------------------------------------------------------
# Backend
# ---------------------------------------------------------------
BACKEND_REST_URL=https://your-backend.onrender.com
BACKEND_WS_URL=wss://your-backend.onrender.com/ws/events

# ---------------------------------------------------------------
# Face recognition
# Set to true only after backend GET /api/persons is live
# ---------------------------------------------------------------
FACE_RECOGNITION_ENABLED=false
FACE_RECOGNITION_INTERVAL=15
FACE_MATCH_THRESHOLD=0.15

# ---------------------------------------------------------------
# MJPEG stream output
# ---------------------------------------------------------------
MJPEG_QUALITY=80
MJPEG_MAX_FPS=25
STREAM_WIDTH=640
STREAM_HEIGHT=480

# ---------------------------------------------------------------
# Threat scoring
# ---------------------------------------------------------------
LOITER_THRESHOLD_SECONDS=30