# PERCEPTRA Backend - Environment Variables
# Copy this file to .env and fill in real values

# Server
PORT=8000
NODE_ENV=development

# Database (PostgreSQL or SQLite)
DATABASE_URL=postgresql://user:password@localhost:5432/perceptra
# Or for SQLite: DATABASE_URL=sqlite://./dev.db

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=24h

# CORS
CORS_ORIGIN=http://localhost:5174

# Twilio (for SMS alerts - Isabelle)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# SMTP (for Email alerts - Isabelle)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
